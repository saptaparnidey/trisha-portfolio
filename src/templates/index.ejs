<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title><%= site.title %></title>
    <link rel="preconnect" href="https://fonts.googleapis.com">
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@300;400;500;600;700&family=Playfair+Display:wght@600;700&display=swap" rel="stylesheet">
<%- include('partials/styles') %>
</head>
<body>
    <!-- Header -->
    <header>
        <div class="header-content">
            <div class="logo"><%= site.logo %></div>
            <nav>
                <ul class="nav-links">
                    <li><a href="#home">Home</a></li>
                    <li><a href="#about">About</a></li>
                    <li><a href="#portfolio">Portfolio</a></li>
                    <li><a href="#contact">Contact</a></li>
                </ul>
            </nav>
        </div>
    </header>

    <!-- Hero Section -->
    <section id="home" class="hero">
        <div class="hero-content fade-in-up">
            <h1><%= hero.name %></h1>
            <p class="subtitle"><%= hero.subtitle %></p>
            <p class="description"><%= hero.description %></p>
            <div class="cta-buttons">
                <a href="<%= hero.primaryBtn.href %>" class="btn btn-primary"><%= hero.primaryBtn.label %></a>
                <a href="<%= hero.secondaryBtn.href %>" class="btn btn-secondary"><%= hero.secondaryBtn.label %></a>
            </div>
        </div>
    </section>

    <!-- Author Section -->
    <section id="about" class="author-section">
        <div class="author-content">
            <div class="author-image">
                <img src="<%= about.image %>" alt="<%= about.imageAlt %>">
            </div>
            <div class="author-text">
                <h2><%= about.heading %></h2>
                <p class="tagline"><%= about.tagline %></p>
                <% about.paragraphs.forEach(function(para) { %>
                <p><%= para %></p>
                <% }); %>
                <div class="skills">
                    <% about.skills.forEach(function(skill) { %>
                    <span class="skill-tag"><%= skill %></span>
                    <% }); %>
                </div>
            </div>
        </div>
    </section>

    <!-- Portfolio Section -->
    <section id="portfolio" class="portfolio-section">
        <div class="portfolio-content">
            <div class="section-header">
                <h2><%= portfolio.heading %></h2>
                <p><%= portfolio.subheading %></p>
            </div>
            <div class="portfolio-grid">
                <% portfolio.projects.forEach(function(project) { %>
                <div class="portfolio-card">
                    <img src="<%= project.cardImage %>" alt="<%= project.cardImageAlt %>" class="card-image">
                    <div class="card-content">
                        <span class="card-category"><%= project.category %></span>
                        <h3 class="card-title"><%= project.title %></h3>
                        <p class="card-description"><%= project.description %></p>
                        <a href="<%= projectsSubdir %>/<%= project.slug %>.html" class="card-link">
                            View Project
                            <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><line x1="5" y1="12" x2="19" y2="12"></line><polyline points="12 5 19 12 12 19"></polyline></svg>
                        </a>
                    </div>
                </div>
                <% }); %>
            </div>
        </div>
    </section>

    <!-- Contact Section -->
    <section id="contact" class="contact-section">
        <div class="contact-content">
            <h2><%= contact.heading %></h2>
            <p><%= contact.subtext %></p>
            <div class="contact-methods">
                <div class="contact-card">
                    <h3>Email Me</h3>
                    <a href="mailto:<%= contact.email %>"><%= contact.email %></a>
                </div>
                <div class="contact-card">
                    <h3>Book a Call</h3>
                    <a href="<%= contact.whatsappLink %>" target="_blank">WhatsApp: <%= contact.whatsapp %></a>
                </div>
            </div>
            <div class="social-links">
                <% if (contact.instagram) { %>
                <a href="<%= contact.instagram %>" target="_blank" class="social-link" aria-label="Instagram">
                    <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24"><path d="M12 2.163c3.204 0 3.584.012 4.85.07 3.252.148 4.771 1.691 4.919 4.919.058 1.265.069 1.645.069 4.849 0 3.205-.012 3.584-.069 4.849-.149 3.225-1.664 4.771-4.919 4.919-1.266.058-1.644.07-4.85.07-3.204 0-3.584-.012-4.849-.07-3.26-.149-4.771-1.699-4.919-4.92-.058-1.265-.07-1.644-.07-4.849 0-3.204.013-3.583.07-4.849.149-3.227 1.664-4.771 4.919-4.919 1.266-.057 1.645-.069 4.849-.069zm0-2.163c-3.259 0-3.667.014-4.947.072-4.358.2-6.78 2.618-6.98 6.98-.059 1.281-.073 1.689-.073 4.948 0 3.259.014 3.668.072 4.948.2 4.358 2.618 6.78 6.98 6.98 1.281.058 1.689.072 4.948.072 3.259 0 3.668-.014 4.948-.072 4.354-.2 6.782-2.618 6.979-6.98.059-1.28.073-1.689.073-4.948 0-3.259-.014-3.667-.072-4.947-.196-4.354-2.617-6.78-6.979-6.98-1.281-.059-1.69-.073-4.949-.073zm0 5.838c-3.403 0-6.162 2.759-6.162 6.162s2.759 6.163 6.162 6.163 6.162-2.759 6.162-6.163c0-3.403-2.759-6.162-6.162-6.162zm0 10.162c-2.209 0-4-1.79-4-4 0-2.209 1.791-4 4-4s4 1.791 4 4c0 2.21-1.791 4-4 4zm6.406-11.845c-.796 0-1.441.645-1.441 1.44s.645 1.44 1.441 1.44c.795 0 1.439-.645 1.439-1.44s-.644-1.44-1.439-1.44z"/></svg>
                </a>
                <% } %>
                <% if (contact.linkedin) { %>
                <a href="<%= contact.linkedin %>" target="_blank" class="social-link" aria-label="LinkedIn">
                    <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24"><path d="M19 0h-14c-2.761 0-5 2.239-5 5v14c0 2.761 2.239 5 5 5h14c2.762 0 5-2.239 5-5v-14c0-2.761-2.238-5-5-5zm-11 19h-3v-11h3v11zm-1.5-12.268c-.966 0-1.75-.79-1.75-1.764s.784-1.764 1.75-1.764 1.75.79 1.75 1.764-.783 1.764-1.75 1.764zm13.5 12.268h-3v-5.604c0-3.368-4-3.113-4 0v5.604h-3v-11h3v1.765c1.396-2.586 7-2.777 7 2.476v6.759z"/></svg>
                </a>
                <% } %>
            </div>
        </div>
    </section>

    <!-- Footer -->
    <footer>
        <% footer.lines.forEach(function(line) { %>
        <p><%= line %></p>
        <% }); %>
    </footer>

    <script>
        // Handle image loading errors with fallback colors
        document.addEventListener('DOMContentLoaded', function() {
            const images = document.querySelectorAll('.card-image');
            const categoryColors = {
                'Copywriting': 'linear-gradient(135deg, #ffeaa7 0%, #fdcb6e 100%)',
                'YouTube Optimization': 'linear-gradient(135deg, #ff7675 0%, #fd79a8 100%)',
                'YouTube Video': 'linear-gradient(135deg, #ff7675 0%, #fd79a8 100%)',
                'Email Marketing': 'linear-gradient(135deg, #74b9ff 0%, #0984e3 100%)',
                'Social Media': 'linear-gradient(135deg, #a29bfe 0%, #6c5ce7 100%)',
                'Marketing Campaign': 'linear-gradient(135deg, #fd79a8 0%, #e84393 100%)',
                'Content Strategy': 'linear-gradient(135deg, #55efc4 0%, #00b894 100%)',
                'SEO Content': 'linear-gradient(135deg, #81ecec 0%, #00cec9 100%)'
            };

            images.forEach(img => {
                img.onerror = function() {
                    const card = this.closest('.portfolio-card');
                    const category = card.querySelector('.card-category').textContent.trim();
                    const gradient = categoryColors[category] || 'linear-gradient(135deg, #dfe6e9 0%, #b2bec3 100%)';
                    this.style.background = gradient;
                    this.alt = '';
                };
            });

            // Smooth scroll for navigation
            document.querySelectorAll('a[href^="#"]').forEach(anchor => {
                anchor.addEventListener('click', function (e) {
                    e.preventDefault();
                    const target = document.querySelector(this.getAttribute('href'));
                    if (target) {
                        target.scrollIntoView({
                            behavior: 'smooth',
                            block: 'start'
                        });
                    }
                });
            });
        });
    </script>
</body>
</html>
